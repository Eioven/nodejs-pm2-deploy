# Скопируйте этот файл в .env.deploy и заполните значения.
# Файл .env.deploy не должен попадать в репозиторий.

# IP-адрес или домен удалённого сервера
DEPLOY_HOST=your.server.ip

# Пользователь на удалённом сервере
DEPLOY_USER=user

# URL репозитория (HTTPS или SSH)
DEPLOY_REPO=https://github.com/your-username/web-plus-pm2-deploy.git

# Путь на сервере, куда деплоить приложение
DEPLOY_PATH=/var/www/app

# Ветка для деплоя (по умолчанию origin/main)
DEPLOY_REF=origin/main

# Путь к приватному SSH-ключу для подключения к серверу (опционально)
# DEPLOY_SSH_KEY=~/.ssh/id_rsa
